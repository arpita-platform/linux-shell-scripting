#Bash script to automate Linux user account creation, generate a password, set account details, and force password change on first login.

#!/bin/bash

# Check if script is run as root.

if [[ "$UID" -ne 0 ]]
then
echo "Please run with sudo or root."
exit 1
fi

# Check if at least one argument is provided.

if [[ $# -lt 1 ]]
then
echo "Usage: $0 USER_NAME [COMMENT]"
echo "Create a user with name USER_NAME and optional COMMENT."
exit 1
fi

# Store first argument as username.

USER_NAME="$1"

# Store remaining arguments as comment.

shift
COMMENT="$*"

# Generate a password.

PASSWORD=$(date +%s%N)

# Create the user.

useradd -c "$COMMENT" -m "$USER_NAME"

# Verify user creation.

if [[ $? -ne 0 ]]
then
echo "The account could not be created."
exit 1
fi

# Set the password.

echo "${USER_NAME}:${PASSWORD}" | chpasswd

# Verify password creation.

if [[ $? -ne 0 ]]
then
echo "Password could not be set."
exit 1
fi

# Force password change on first login.

passwd -e "$USER_NAME"

# Display account information.

echo
echo "User account created successfully."
echo "Username : $USER_NAME"
echo "Password : $PASSWORD"
echo "Host     : $(hostname)"

                                         
                         
